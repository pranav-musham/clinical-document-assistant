# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clinical_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# File Upload Settings
MAX_FILE_SIZE_MB=25
ALLOWED_AUDIO_FORMATS=audio/mpeg,audio/wav,audio/m4a,audio/webm,audio/ogg
UPLOAD_DIR=uploads

# API Configuration
API_V1_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
APP_NAME=Clinical Documentation Assistant
VERSION=1.0.0
DEBUG=True
